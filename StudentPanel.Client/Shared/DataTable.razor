@typeparam TItem
<table class="data-table">
    <thead>
    <tr>@HeaderContent</tr>
    </thead>
    <tbody>
    @if
        (Items is null || !Items.Any())
    {
        <tr>
            <td colspan="99" class = "empty-row">No data.</td>
        </tr>
    }
    else
    {
        @foreach
            (var item in Items)
        {
            <tr>
                @RowContent(item)
            </tr>
        }
    }
    </tbody>
</table>
@code
{
    [Parameter, EditorRequired]
    public IEnumerable<TItem>? Items
    {
        get;
        set;
    }

    [Parameter, EditorRequired]
    public RenderFragment HeaderContent { get; set; } = default!;

    [Parameter, EditorRequired] public RenderFragment<TItem> RowContent { get; set; } = default!;
}
