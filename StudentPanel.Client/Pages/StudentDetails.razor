@page "/students/{Id:int}"
@inject StudentsApiClient Api
@inject ObservedStudentsState ObservedState
@inject ClipboardService Clipboard
@implements IAsyncDisposable

<ErrorBoundary>
    <ChildContent>
        <LoadingPanel IsLoading="@_loading" />
        <ApiError Message="@_error" />

        @if (_student is null && !_loading && _error is null)
        {
            <h2>Student not found</h2>
            <p>No student with ID @Id exists.</p>
            <a href="/students">Back to list</a>
        }
        else if (_student is not null)
        {
            <h1>@_student.FirstName @_student.LastName</h1>

            <p><strong>Index:</strong> @_student.IndexNumber</p>

            <p>
                <strong>Email:</strong> @_student.Email
                <button class="btn btn-secondary" @onclick="CopyEmailAsync">Copy email</button>

                @if (_copied)
                {
                    <small> Copied!</small>
                }
            </p>

            <p><strong>Semester:</strong> @_student.Semester</p>

            <button class="btn @(ObservedState.IsObserved(Id) ? "btn-danger" : "btn-secondary")"
                    @onclick="() => ObservedState.Toggle(_student)">
                @(ObservedState.IsObserved(Id) ? "Remove from observed" : "Add to observed")
            </button>

            <hr />

            <h2>Assigned courses</h2>

            <DataTable Items="_courses" TItem="StudentCourseAssignment">
                <HeaderContent>
                    <th>Course</th>
                    <th>ECTS</th>
                    <th>Assigned at</th>
                </HeaderContent>

                <RowContent Context="c">
                    <td>@c.Course?.Name</td>
                    <td>@c.Course?.Ects</td>
                    <td>@c.AssignedAt.ToShortDateString()</td>
                </RowContent>
            </DataTable>

            <hr />

            <h2>Assign a course</h2>

            <EditForm Model="_assignRequest" OnValidSubmit="AssignCourseAsync">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>Course</label>

                    <InputSelect @bind-Value="_assignRequest.CourseId">
                        <option value="0">-- select --</option>

                        @foreach (var c in _availableCourses)
                        {
                            <option value="@c.Id">@c.Name (@c.Ects ECTS)</option>
                        }
                    </InputSelect>

                    <ValidationMessage For="() => _assignRequest.CourseId" class="validation-message" />
                </div>

                <button type="submit" class="btn btn-primary">Assign</button>
            </EditForm>
        }
    </ChildContent>

    <ErrorContent Context="ex">
        <p class="api-error">Details failed to load: @ex.Message</p>
    </ErrorContent>
</ErrorBoundary>

@code {
    [Parameter] public int Id { get; set; }

    private StudentDto? _student;
    private List<StudentCourseAssignment> _courses = new();
    private List<CourseDto> _availableCourses = new();
    private AssignCourseRequest _assignRequest = new();

    private bool _loading = true;
    private string? _error;
    private bool _copied;
    private bool _jsReady;

    protected override async Task OnInitializedAsync()
    {
        _availableCourses = await Api.GetCoursesAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;
        _student = null;
        _courses = new();

        try
        {
            _student = await Api.GetStudentAsync(Id);

            if (_student is not null)
            {
                _courses = await Api.GetStudentCoursesAsync(Id);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsReady = true;
        }

        return Task.CompletedTask;
    }

    private async Task CopyEmailAsync()
    {
        if (_student is null)
        {
            return;
        }

        await Clipboard.CopyAsync(_student.Email);

        _copied = true;
        StateHasChanged();

        await Task.Delay(2000);

        _copied = false;
        StateHasChanged();
    }

    private async Task AssignCourseAsync()
    {
        if (_student is null)
        {
            return;
        }

        var success = await Api.AssignCourseAsync(Id, _assignRequest.CourseId);

        if (success)
        {
            _courses = await Api.GetStudentCoursesAsync(Id);
            _assignRequest = new();
        }
    }

    public async ValueTask DisposeAsync()
    {
        await Clipboard.DisposeAsync();
    }
}